---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthorCard from '../components/AuthorCard.astro';
import TabBar from '../components/TabBar.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { loadConfig } from '../lib/config';
import { getAllCategories, getArticlesByCategory } from '../lib/data';
import { categorySlug } from '../lib/category';

const config = loadConfig();
const categories = await getAllCategories();
const defaultSlug = categorySlug(config.notion.defaultCategory);
const articles = await getArticlesByCategory(defaultSlug);
---

<BaseLayout>
  <AuthorCard />
  <TabBar categories={categories} activeSlug={defaultSlug} />

  <div class="article-list">
    {articles.length === 0 && <p>目前沒有文章。</p>}
    {articles.map((article) => (
      <ArticleCard
        title={article.title}
        articleId={article.id}
        categorySlug={defaultSlug}
        createdTime={article.createdTime}
      />
    ))}
  </div>
</BaseLayout>
