---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import TabBar from '../../components/TabBar.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getAllCategories, getArticlesByCategory } from '../../lib/data';

export async function getStaticPaths() {
  const categories = await getAllCategories();
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: { categoryName: cat.name },
  }));
}

const { category } = Astro.params;
const { categoryName } = Astro.props;
const categories = await getAllCategories();
const articles = await getArticlesByCategory(category!);
---

<BaseLayout title={categoryName}>
  <AuthorCard />
  <TabBar categories={categories} activeSlug={category!} />

  <div class="article-list">
    {articles.length === 0 && <p>目前沒有文章。</p>}
    {articles.map((article) => (
      <ArticleCard
        title={article.title}
        articleId={article.id}
        categorySlug={category!}
        createdTime={article.createdTime}
      />
    ))}
  </div>
</BaseLayout>
