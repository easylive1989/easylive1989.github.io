---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotionRenderer from '../../components/notion/NotionRenderer.astro';
import { loadConfig } from '../../lib/config';
import { getArticle, getAllArticlesForStaticPaths, getArticlesByCategory } from '../../lib/data';

export async function getStaticPaths() {
  const paths = await getAllArticlesForStaticPaths();
  return paths.map((p) => ({
    params: { category: p.categorySlug, slug: p.articleId },
  }));
}

const { category, slug } = Astro.params;
const data = await getArticle(category!, slug!);

if (!data) {
  return Astro.redirect('/404');
}

const { article, blocks, categorySlug, categoryName } = data;

const allArticles = await getArticlesByCategory(categorySlug);
const currentIndex = allArticles.findIndex((a) => a.id === slug);
const prevArticle = currentIndex < allArticles.length - 1 ? allArticles[currentIndex + 1] : null;
const nextArticle = currentIndex > 0 ? allArticles[currentIndex - 1] : null;

const formattedDate = new Date(article.createdTime).toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const config = loadConfig();
---

<BaseLayout title={article.title}>
  <article class="article-page">
    <div class="article-top-bar">
      <a href={`${import.meta.env.BASE_URL}${categorySlug}/`} class="back-link">&larr; {categoryName}</a>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <svg class="theme-icon sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2" x2="12" y2="5"/>
          <line x1="12" y1="19" x2="12" y2="22"/>
          <line x1="4.93" y1="4.93" x2="7.05" y2="7.05"/>
          <line x1="16.95" y1="16.95" x2="19.07" y2="19.07"/>
          <line x1="2" y1="12" x2="5" y2="12"/>
          <line x1="19" y1="12" x2="22" y2="12"/>
          <line x1="4.93" y1="19.07" x2="7.05" y2="16.95"/>
          <line x1="16.95" y1="7.05" x2="19.07" y2="4.93"/>
        </svg>
        <svg class="theme-icon moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
        </svg>
      </button>
    </div>

    <header class="article-header">
      <h1>{article.title}</h1>
      <div class="article-meta">
        <time datetime={article.createdTime}>{formattedDate}</time>
      </div>
    </header>

    <div class="article-content">
      <NotionRenderer blocks={blocks} />
    </div>

    <nav class="article-nav">
      {prevArticle && (
        <a href={`${import.meta.env.BASE_URL}${categorySlug}/${prevArticle.id}/`} class="nav-prev">
          &larr; {prevArticle.title}
        </a>
      )}
      {nextArticle && (
        <a href={`${import.meta.env.BASE_URL}${categorySlug}/${nextArticle.id}/`} class="nav-next">
          {nextArticle.title} &rarr;
        </a>
      )}
    </nav>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": article.title,
    "datePublished": article.createdTime,
    "author": {
      "@type": "Person",
      "name": config.author.name,
    },
    "publisher": {
      "@type": "Organization",
      "name": config.site.title,
    },
  })} />
</BaseLayout>
