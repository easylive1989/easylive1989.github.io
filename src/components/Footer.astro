---
import { loadConfig } from '../lib/config';
const config = loadConfig();

const iconSvgMap: Record<string, { svg: string; label: string }> = {
  github: {
    svg: '<path d="M6 7 L4 1 L10 6Z" fill="currentColor"/><path d="M18 7 L20 1 L14 6Z" fill="currentColor"/><circle cx="12" cy="13" r="8.5" fill="currentColor"/><circle cx="9" cy="11.5" r="2.2" fill="white"/><circle cx="15" cy="11.5" r="2.2" fill="white"/><circle cx="9.8" cy="11.5" r="1.2" fill="currentColor"/><circle cx="15.8" cy="11.5" r="1.2" fill="currentColor"/><circle cx="9.2" cy="10.8" r="0.5" fill="white"/><circle cx="15.2" cy="10.8" r="0.5" fill="white"/><ellipse cx="12" cy="15" rx="1" ry="0.6" fill="white"/><path d="M10.5 16 Q12 17.5 13.5 16" stroke="white" stroke-width="0.8" fill="none" stroke-linecap="round"/>',
    label: 'GitHub',
  },
  threads: {
    svg: '<circle cx="12" cy="12" r="9.5" stroke="currentColor" stroke-width="3" fill="none"/><path d="M15 7.5 L15 12 A3 3 0 1 1 12 9" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="1" fill="currentColor"/>',
    label: 'Threads',
  },
  email: {
    svg: '<rect x="2" y="5" width="20" height="14" rx="3" fill="currentColor"/><path d="M3.5 7 L12 14 L20.5 7" stroke="white" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 10.5 C11.5 10 10.5 10 10.5 10.8 C10.5 11.5 12 12.8 12 12.8 C12 12.8 13.5 11.5 13.5 10.8 C13.5 10 12.5 10 12 10.5Z" fill="white"/>',
    label: 'Email',
  },
};
---

<footer>
  <div class="footer-links">
    {config.author.links.map((link) => {
      const icon = iconSvgMap[link.type];
      return (
        <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={icon?.label ?? link.type}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" set:html={icon?.svg ?? ''} />
        </a>
      );
    })}
  </div>
  <p class="copyright">
    &copy; {new Date().getFullYear()} {config.author.name}
  </p>
</footer>
