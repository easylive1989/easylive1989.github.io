---
import { loadConfig } from '../lib/config';
const config = loadConfig();
---

<header>
  <nav>
    <a href={import.meta.env.BASE_URL} class="site-title">{config.site.title}</a>
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
      <svg class="theme-icon sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"/>
        <line x1="12" y1="2" x2="12" y2="5"/>
        <line x1="12" y1="19" x2="12" y2="22"/>
        <line x1="4.93" y1="4.93" x2="7.05" y2="7.05"/>
        <line x1="16.95" y1="16.95" x2="19.07" y2="19.07"/>
        <line x1="2" y1="12" x2="5" y2="12"/>
        <line x1="19" y1="12" x2="22" y2="12"/>
        <line x1="4.93" y1="19.07" x2="7.05" y2="16.95"/>
        <line x1="16.95" y1="7.05" x2="19.07" y2="4.93"/>
      </svg>
      <svg class="theme-icon moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
      </svg>
    </button>
  </nav>
</header>

<style>
  .theme-icon {
    display: none;
  }
  /* In light mode, show moon icon (click to switch to dark) */
  :global(:root) .moon-icon {
    display: block;
  }
  /* In dark mode, show sun icon (click to switch to light) */
  :global([data-theme="dark"]) .sun-icon {
    display: block;
  }
  :global([data-theme="dark"]) .moon-icon {
    display: none;
  }
</style>
