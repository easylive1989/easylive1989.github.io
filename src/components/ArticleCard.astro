---
interface Props {
  title: string;
  articleId: string;
  categorySlug: string;
  createdTime: string;
}

const { title, articleId, categorySlug, createdTime } = Astro.props;

const formattedDate = new Date(createdTime).toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`${import.meta.env.BASE_URL}${categorySlug}/${articleId}/`} class="article-card">
  <h3 class="article-title">{title}</h3>
  <div class="article-meta">
    <time datetime={createdTime}>{formattedDate}</time>
  </div>
</a>
