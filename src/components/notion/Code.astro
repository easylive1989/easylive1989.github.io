---
import type { NotionBlock } from '../../lib/notion';
import { createHighlighter, type BundledLanguage, bundledLanguages } from 'shiki';

interface Props { block: NotionBlock; }
const { block } = Astro.props;
const code = (block as any).code;
const notionLang = code.language || 'plain text';
const text = code.rich_text.map((t: any) => t.plain_text).join('');
const caption = code.caption?.map((t: any) => t.plain_text).join('') ?? '';

const lang: BundledLanguage | 'text' = notionLang in bundledLanguages
  ? notionLang as BundledLanguage
  : 'text';

const langs = lang === 'text' ? [] : [lang];
const highlighter = await createHighlighter({
  themes: ['github-light'],
  langs,
});

const html = highlighter.codeToHtml(text, { lang, theme: 'github-light' });
---
<div class="code-block">
  <div class="code-header">
    <span class="code-language">{notionLang}</span>
  </div>
  <Fragment set:html={html} />
  {caption && <p class="code-caption">{caption}</p>}
</div>
